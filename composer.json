{
    "name": "wttks/laravel-csv",
    "description": "Laravel CSV/TSV reader and writer with Japanese encoding support",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Wttks\\Csv\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wttks\\Csv\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wttks\\Csv\\CsvServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
